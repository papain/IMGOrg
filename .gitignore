# Personal documents — never commit receipts, health records, etc.
inbox/*
archive/*
!inbox/.gitkeep
!archive/.gitkeep

# Personal data store — REPO IS PUBLIC, real data must never be committed.
# data/data.js lives only on your machine; fresh clones copy data/data.example.js.
data/data.js
data/data.local.js

# Local Claude Code settings (machine-specific permissions)
.claude/settings.local.json

# Unrelated local project — not part of the receipt app
SCORM/

# OS noise
Thumbs.db
desktop.ini
.DS_Store
